    if(smokes.length>0) problems.push({type:'orange',msg:`🚬 담배 ${smokes.length}회(${fmt(smokes.reduce((s,t)=>s+t.amt,0))}원) — 건강과 지갑 모두 챙겨요`});
    if(beauty>100000) problems.push({type:'blue',msg:`👗 꾸밈비 ${fmt(beauty)}원 — 예산 내 소비인지 확인`});
    if(pet.length>0) problems.push({type:'blue',msg:`🐶 반려동물 지출 ${fmt(pet.reduce((s,t)=>s+t.amt,0))}원 — 월 예산 책정 필요`});
    if(isGood) problems.push({type:'green',msg:`✅ 전주보다 ${Math.abs(chg).toFixed(0)}% 절약! 잘 하고 있어요`});
    if(!problems.length) problems.push({type:'green',msg:`✅ 이번 주 지출 패턴 양호해요`});

    return `<div class="wdetail${isWarn?' warn':isGood?' ok':''}">
      <div class="wdtop">
        <div class="wdtitle">${w.w}주차 <span style="font-size:9px;color:var(--text3);font-weight:400">${WD[w.w]||''}</span></div>
