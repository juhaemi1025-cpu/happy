    </div>`).join('')}
  </div>
  ${monthProblems}`;
}
function selectHomeMonth(mk){renderHome(mk);}

function getMonthProblems(txs,cats,inc,exp,net){
  const problems=[];
  const deliveries=txs.filter(t=>t.name.includes('배달')||t.name.includes('배민'));
  const smokes=txs.filter(t=>t.name.includes('담배'));
  const petTotal=txs.filter(t=>t.name.includes('코코')||t.name.includes('도비')).reduce((s,t)=>s+t.amt,0);
  const saveRate=inc>0?Math.round(net/inc*100):0;

  if(net<0) problems.push({type:'red',icon:'🔴',title:'적자 발생!',desc:`수입보다 지출이 ${fmt(Math.abs(net))}원 많아요. 지출 구조 점검이 필요해요.`});
  if(saveRate>0&&saveRate<20&&inc>0) problems.push({type:'orange',icon:'⚠️',title:'저축률 낮음',desc:`저축률 ${saveRate}% — 목표 20% 이상을 권장해요.`});
  if((cats['식비']||0)>800000) problems.push({type:'red',icon:'🍽️',title:'식비 과다',desc:`식비 ${fmt(cats['식비'])}원 — 월 목표 80만원 초과! ${fmt((cats['식비']||0)-800000)}원 초과`});
  if(deliveries.length>=8) problems.push({type:'orange',icon:'🛵',title:'배달 과다',desc:`배달 ${deliveries.length}회(${fmt(deliveries.reduce((s,t)=>s+t.amt,0))}원) — 주 2회 이하로 줄여보세요`});
  if(smokes.length>0) problems.push({type:'orange',icon:'🚬',title:'담배 지출',desc:`담배 ${smokes.length}회(${fmt(smokes.reduce((s,t)=>s+t.amt,0))}원) — 금연하면 연 ${fmt(smokes.reduce((s,t)=>s+t.amt,0)*12)}원 절약`});
  if((cats['기타']||0)>300000) problems.push({type:'blue',icon:'📦',title:'기타 지출 큼',desc:`기타 ${fmt(cats['기타'])}원 — 세부 카테고리로 분류해보세요`});
  if(petTotal>200000) problems.push({type:'blue',icon:'🐾',title:'반려동물 비용',desc:`반려동물 ${fmt(petTotal)}원 — 월 예산을 정해두면 좋아요`});
  if((cats['꾸밈비']||0)>300000) problems.push({type:'blue',icon:'👗',title:'꾸밈비 과다',desc:`꾸밈비 ${fmt(cats['꾸밈비'])}원 — 목표 예산 설정을 권장해요`});
  if(!problems.length) problems.push({type:'green',icon:'✅',title:'이달 재정 양호!',desc:'큰 문제점이 없어요. 이 패턴을 유지해보세요!'});

  return `<div style="background:linear-gradient(135deg,#fff0f4,#fff8f0);border-radius:16px;padding:14px;margin-bottom:10px;border:1px solid #ffccd5">
    <div style="font-size:12px;font-weight:800;color:var(--pink);margin-bottom:9px">⚠️ 이달 종합 문제점 & 조언</div>
    ${problems.map(p=>`<div class="problem-box ${p.type}"><b>${p.icon} ${p.title}</b><br>${p.desc}</div>`).join('')}
  </div>`;
}

