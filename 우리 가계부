// ===== MODAL ASSET =====
function openAssetModal(){
  document.getElementById('modal-asset-title').textContent='🏦 자산 항목 추가';
  document.getElementById('as-edit-key').value='';
  document.getElementById('as-name').value='';document.getElementById('as-amt').value='';
  document.getElementById('as-date').value=new Date().toISOString().slice(0,10);
  document.getElementById('modal-asset').classList.add('on');
}
function openEditAsset(key){
  const snaps=ASSET_SNAPSHOTS.sort((a,b)=>a.date.localeCompare(b.date));
  const latest=snaps[snaps.length-1];
  const item=latest?.items.find(i=>i.key===key);
  if(!item)return;
  document.getElementById('modal-asset-title').textContent='✏️ 자산 수정';
  document.getElementById('as-edit-key').value=key;
  document.getElementById('as-name').value=item.name;
  document.getElementById('as-cat').value=item.cat;
  document.getElementById('as-amt').value=item.amt;
  document.getElementById('as-date').value=latest.date;
  document.getElementById('modal-asset').classList.add('on');
}
function closeAssetModal(){document.getElementById('modal-asset').classList.remove('on');}
function saveAsset(){
  const key=document.getElementById('as-edit-key').value;
  const name=document.getElementById('as-name').value.trim();
  const cat=document.getElementById('as-cat').value;
  const amt=parseFloat(document.getElementById('as-amt').value)||0;
  const date=document.getElementById('as-date').value;
  if(!name){alert('자산명을 입력해주세요');return;}
  const itemKey=key||(cat+'_'+name.replace(/ /g,''));
  // 해당 날짜 스냅샷 찾거나 새로 생성
  let snap=ASSET_SNAPSHOTS.find(s=>s.date===date);
  if(!snap){
    // 가장 최근 스냅샷 복사
    const sorted=ASSET_SNAPSHOTS.sort((a,b)=>a.date.localeCompare(b.date));
    const prev=sorted[sorted.length-1];
    snap={date,label:date.slice(0,7).replace('-','년 ')+'월',items:prev?[...prev.items.map(i=>({...i}))]:[]};
    ASSET_SNAPSHOTS.push(snap);
  }
  const existing=snap.items.findIndex(i=>i.key===itemKey);
  const newItem={key:itemKey,name,cat,amt};
  if(existing>-1)snap.items[existing]=newItem;else snap.items.push(newItem);
  save();closeAssetModal();renderAsset();
}

