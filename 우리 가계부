const fmt=n=>n?Math.abs(Math.round(n)).toLocaleString('ko-KR'):'0';
const fmtK=n=>{const a=Math.abs(n);return a>=100000000?Math.round(a/100000000*10)/10+'억':a>=10000?Math.round(a/10000)+'만':Math.round(a/1000)+'k';};
const uid=()=>'u'+Date.now()+Math.random().toString(36).slice(2,6);

// ===== MONTHS (동적 생성) =====
function getMonths(){
  const set=new Set();
  TX.forEach(t=>set.add(`${t.year}_${t.month}`));
  SAVING.forEach(s=>{const d=new Date(s.date);set.add(`${d.getFullYear()}_${d.getMonth()+1}`);});
  // 최소 기본 월 보장
  ['2025_12','2026_1','2026_2','2026_3','2026_4','2026_5'].forEach(m=>set.add(m));
  return [...set].sort((a,b)=>{
    const[ay,am]=a.split('_').map(Number);const[by,bm]=b.split('_').map(Number);
    return ay!==by?ay-by:am-bm;
  }).map(k=>{
    const[y,m]=k.split('_').map(Number);
    return{key:k,label:`${String(y).slice(2)}년 ${m}월`};
  });
}

// ===== STORAGE =====
function save(){
  try{
    localStorage.setItem('tx3',JSON.stringify(TX));
    localStorage.setItem('sv3',JSON.stringify(SAVING));
    localStorage.setItem('fx3',JSON.stringify(FIXED));
    localStorage.setItem('pu3',JSON.stringify(PURPOSE));
    localStorage.setItem('as3',JSON.stringify(ASSET_SNAPSHOTS));
  }catch(e){}
}
function load(){
  try{
    TX=JSON.parse(localStorage.getItem('tx3')||'null')||[...DEFAULT_TX];
    SAVING=JSON.parse(localStorage.getItem('sv3')||'null')||[...DEFAULT_SAVING];
    FIXED=JSON.parse(localStorage.getItem('fx3')||'null')||[...DEFAULT_FIXED];
    PURPOSE=JSON.parse(localStorage.getItem('pu3')||'null')||[...DEFAULT_PURPOSE];
    ASSET_SNAPSHOTS=JSON.parse(localStorage.getItem('as3')||'null')||[...DEFAULT_ASSET_SNAPSHOTS];
  }catch(e){TX=[...DEFAULT_TX];SAVING=[...DEFAULT_SAVING];FIXED=[...DEFAULT_FIXED];PURPOSE=[...DEFAULT_PURPOSE];ASSET_SNAPSHOTS=[...DEFAULT_ASSET_SNAPSHOTS];}
}

// ===== HELPERS =====
function getMTx(mk){const[y,m]=mk.split('_').map(Number);return TX.filter(t=>t.year===y&&t.month===m);}
function getExp(mk){return getMTx(mk).filter(t=>t.type==='지출');}
function getInc(mk){return getMTx(mk).filter(t=>t.type==='수입');}
function getCatTotals(txs){const r={};txs.forEach(t=>{r[t.cat]=(r[t.cat]||0)+t.amt;});return r;}
function getWeekTotals(txs){const r={};txs.forEach(t=>{const w=t.week||1;r[w]=(r[w]||0)+t.amt;});return r;}

// ===== NAVIGATION =====
function goBack(){
  if(pgHistory.length>1){pgHistory.pop();_showPg(pgHistory[pgHistory.length-1]);}
}
function showPg(name){
  if(pgHistory[pgHistory.length-1]!==name)pgHistory.push(name);
  _showPg(name);
}
function _showPg(name){
  document.querySelectorAll('.pg').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.nbtn').forEach(b=>b.classList.remove('on'));
  document.getElementById('pg-'+name).classList.add('on');
  const idx=['home','detail','income','saving','asset','compare','fixed','purpose'].indexOf(name);
  if(idx>=0)document.querySelectorAll('.nbtn')[idx].classList.add('on');
  const fabPages=['detail','income','saving'];
  document.getElementById('fab-btn').style.display=fabPages.includes(name)?'flex':'none';
  const MONTHS=getMonths();
  if(name==='home')renderHome(curMonth);
  if(name==='detail'){renderMTabs('detail-mtabs',curMonth,'selectDetailMonth');renderDetail(curMonth,curCat);}
  if(name==='income'){renderMTabs('income-mtabs',curMonth,'selectIncomeMonth');renderIncome(curMonth);}
  if(name==='saving'){renderSavingMTabs();renderSaving(curSavingMonth);}
  if(name==='asset')renderAsset();
  if(name==='compare')renderCompare();
  if(name==='fixed')renderFixed();
  if(name==='purpose')renderPurpose();
}

