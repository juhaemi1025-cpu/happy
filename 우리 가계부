      <div style="margin-bottom:7px">
        ${topItems.map(t=>`<div style="font-size:10px;color:var(--text2);padding:1px 0">• ${t.name} <b style="color:var(--text)">${fmt(t.amt)}원</b></div>`).join('')}
      </div>
