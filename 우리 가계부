        ${wCats.slice(0,4).map(([c,a])=>`<span style="background:${CAT_BG[c]||'#f0eef8'};color:${CAT_COLOR[c]||'#9b7fe8'};border-radius:7px;padding:2px 7px;font-size:9px;font-weight:700">${CAT_EMOJI[c]||''}${c} ${fmtK(a)}</span>`).join('')}
