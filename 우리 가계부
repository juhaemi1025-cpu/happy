function renderCompare(){
  const MONTHS=getMonths();
  const mks=MONTHS.map(m=>m.key);
  const subHtml=`<div class="ctabs">
    <button class="ctab${compareSub==='expense'?' on':''}" onclick="setCompareSub('expense')">💸 지출</button>
    <button class="ctab${compareSub==='income'?' on':''}" onclick="setCompareSub('income')">💵 수입</button>
    <button class="ctab${compareSub==='net'?' on':''}" onclick="setCompareSub('net')">💚 순수지</button>
  </div>`;
  if(compareSub==='expense'){
    const maxTotal=Math.max(...mks.map(mk=>getExp(mk).reduce((s,t)=>s+t.amt,0)),1);
    const allCats=['식비','생활용품','건강','자녀','자동차','꾸밈비','자기계발','경조사','기타','고정 지출','여행'];
    const barHtml=mks.map(mk=>{const total=getExp(mk).reduce((s,t)=>s+t.amt,0);const pct=Math.round(total/maxTotal*100);
      return `<div class="cmpbar"><div class="cmplbl">${MONTHS.find(m=>m.key===mk)?.label||mk}</div>
        <div class="cmptrack"><div class="cmpfill" style="width:${pct}%;background:${mk===curMonth?'#e05070':'#ffb3c6'}"><span class="cmpftxt">${fmtK(total)}</span></div></div>
        <div class="cmpamt">${fmt(total)}</div></div>`;}).join('');
    const tblRows=allCats.map(cat=>{const vals=mks.map(mk=>getExp(mk).filter(t=>t.cat===cat).reduce((s,t)=>s+t.amt,0));if(vals.every(v=>v===0))return'';const max=Math.max(...vals);
      return `<tr><td>${CAT_EMOJI[cat]||''} ${cat}</td>${vals.map(v=>`<td style="${v===max&&v>0?'color:#e05070;font-weight:800;':''}">${v>0?fmtK(v):'—'}</td>`).join('')}</tr>`;}).join('');
    document.getElementById('compare-body').innerHTML=`${subHtml}<div class="card fade"><div class="ctitle">📈 월별 지출 합계</div>${barHtml}</div>
    <div class="card fade"><div class="ctitle">📊 카테고리 × 월</div><div style="overflow-x:auto"><table class="tbl" style="min-width:280px">
      <thead><tr><th>카테고리</th>${MONTHS.map(m=>`<th>${m.label.slice(0,5)}</th>`).join('')}</tr></thead>
      <tbody>${tblRows}<tr><td>합계</td>${mks.map(mk=>`<td>${fmtK(getExp(mk).reduce((s,t)=>s+t.amt,0))}</td>`).join('')}</tr></tbody></table></div></div>`;
  } else if(compareSub==='income'){
    const maxTotal=Math.max(...mks.map(mk=>getInc(mk).reduce((s,t)=>s+t.amt,0)),1);
    const allIncCats=[...new Set(TX.filter(t=>t.type==='수입').map(t=>t.cat))];
    const barHtml=mks.map(mk=>{const total=getInc(mk).reduce((s,t)=>s+t.amt,0);const pct=Math.round(total/maxTotal*100);
      return `<div class="cmpbar"><div class="cmplbl">${MONTHS.find(m=>m.key===mk)?.label||mk}</div>
        <div class="cmptrack"><div class="cmpfill" style="width:${pct}%;background:${mk===curMonth?'#2ea868':'#80d8a8'}"><span class="cmpftxt">${fmtK(total)}</span></div></div>
        <div class="cmpamt">${fmt(total)}</div></div>`;}).join('');
    const tblRows=allIncCats.map(cat=>{const vals=mks.map(mk=>getInc(mk).filter(t=>t.cat===cat).reduce((s,t)=>s+t.amt,0));if(vals.every(v=>v===0))return'';const max=Math.max(...vals);
      return `<tr><td>${CAT_EMOJI[cat]||'💵'} ${cat}</td>${vals.map(v=>`<td style="${v===max&&v>0?'color:#2ea868;font-weight:800;':''}">${v>0?fmtK(v):'—'}</td>`).join('')}</tr>`;}).join('');
    document.getElementById('compare-body').innerHTML=`${subHtml}<div class="card fade"><div class="ctitle">💵 월별 수입 합계</div>${barHtml}</div>
    <div class="card fade"><div class="ctitle">📊 수입 카테고리 × 월</div><div style="overflow-x:auto"><table class="tbl" style="min-width:280px">
      <thead><tr><th>카테고리</th>${MONTHS.map(m=>`<th>${m.label.slice(0,5)}</th>`).join('')}</tr></thead>
      <tbody>${tblRows}<tr><td>합계</td>${mks.map(mk=>`<td>${fmtK(getInc(mk).reduce((s,t)=>s+t.amt,0))}</td>`).join('')}</tr></tbody></table></div></div>`;
  } else {
    const rows=mks.map(mk=>{const inc=getInc(mk).reduce((s,t)=>s+t.amt,0);const exp=getExp(mk).reduce((s,t)=>s+t.amt,0);const net=inc-exp;const sv=SAVING.filter(s=>{const d=new Date(s.date);return`${d.getFullYear()}_${d.getMonth()+1}`===mk;}).reduce((s,i)=>s+i.amt,0);
      return `<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
        <div><div style="font-size:11px;font-weight:700">${MONTHS.find(m=>m.key===mk)?.label||mk}</div>
        <div style="font-size:9px;color:var(--text3)">수입 ${fmtK(inc)} / 지출 ${fmtK(exp)} / 저축 ${fmtK(sv)}</div></div>
        <div style="text-align:right"><div style="font-size:13px;font-weight:800;color:${net>=0?'#2ea868':'#e05070'}">${net>=0?'+':''}${fmtK(net)}원</div>
        <div style="font-size:9px;color:var(--text3)">${inc>0?`저축률 ${Math.round(net/inc*100)}%`:'수입 미입력'}</div></div>
      </div>`;}).join('');
    document.getElementById('compare-body').innerHTML=`${subHtml}<div class="card fade"><div class="ctitle">💚 월별 수입/지출/순수지</div>${rows}</div>`;
  }
}
function setCompareSub(sub){compareSub=sub;renderCompare();}

