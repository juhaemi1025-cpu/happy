<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>💰 우리 가계부</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4f1fb;--white:#fff;--border:#ece8f8;
  --text:#3d3554;--text2:#7b72a0;--text3:#b0a8cc;
  --shadow:0 2px 16px rgba(120,100,180,.10);
  --purple:#9b7fe8;--mint:#2ea868;--pink:#e05070;--blue:#4070e0;--orange:#e07030;
  --gray:#e8e4f0;--gray-l:#f5f3fa;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;max-width:480px;margin:0 auto;padding-bottom:80px;min-height:100vh}
.bnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--white);border-top:1px solid var(--border);display:flex;z-index:100;box-shadow:0 -4px 20px rgba(120,100,180,.10)}
.nbtn{flex:1;padding:5px 0 7px;display:flex;flex-direction:column;align-items:center;gap:1px;font-size:8.5px;color:var(--text3);font-weight:600;border:none;background:none;cursor:pointer;font-family:'Noto Sans KR',sans-serif;transition:color .2s}
.nbtn.on{color:var(--purple)}
.nbtn .ni{font-size:17px}
.pg{display:none;padding:0 14px 16px}
.pg.on{display:block}
.pghd{padding:16px 0 5px;display:flex;align-items:center;gap:8px}
.back-btn{background:none;border:none;font-size:20px;cursor:pointer;color:var(--text2);padding:2px 4px;flex-shrink:0}
.pgtitle{font-size:19px;font-weight:900;letter-spacing:-.5px;flex:1}
.pgtitle em{color:var(--purple);font-style:normal}
.mtabs{display:flex;gap:6px;overflow-x:auto;padding:0 0 9px;scrollbar-width:none}
.mtabs::-webkit-scrollbar{display:none}
.mtab{flex-shrink:0;padding:5px 12px;border-radius:16px;border:1.5px solid var(--border);background:var(--white);color:var(--text2);font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif;transition:all .2s}
.mtab.on{background:var(--purple);color:#fff;border-color:var(--purple)}
.card{background:var(--white);border-radius:16px;padding:14px;margin-bottom:10px;box-shadow:var(--shadow);border:1px solid var(--border)}
.ctitle{font-size:13px;font-weight:700;margin-bottom:11px;display:flex;align-items:center;gap:5px}
.ctitle .sub{font-size:10px;color:var(--text3);font-weight:400;margin-left:auto}
.hero{border-radius:20px;padding:18px 16px;margin-bottom:10px;position:relative;overflow:hidden}
.hero::after{position:absolute;right:12px;top:12px;font-size:30px;opacity:.22}
.hlabel{font-size:10px;color:var(--text2);letter-spacing:1.5px;margin-bottom:2px;font-weight:600}
.hamount{font-size:26px;font-weight:900;letter-spacing:-1px}
.hamount .won{font-size:15px}
.hchips{margin-top:8px;display:flex;gap:5px;flex-wrap:wrap}
.hchip{background:rgba(255,255,255,.75);border-radius:9px;padding:2px 9px;font-size:10px;color:var(--text2);font-weight:500}
.hchip b{color:var(--text)}
.ie-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.ie-card{border-radius:14px;padding:12px;border:1.5px solid transparent}
.ie-card.income{background:#edfff6;border-color:#b3f0d6}
.ie-card.expense{background:#fff0f4;border-color:#ffccd5}
.ie-lbl{font-size:10px;font-weight:700;margin-bottom:2px}
.ie-lbl.inc{color:var(--mint)}
.ie-lbl.exp{color:var(--pink)}
.ie-amt{font-size:16px;font-weight:900;letter-spacing:-.5px}
.ie-amt.inc{color:var(--mint)}
.ie-amt.exp{color:var(--pink)}
.ie-sub{font-size:10px;color:var(--text3);margin-top:1px}
.net-card{border-radius:14px;padding:12px 14px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.net-pos{background:linear-gradient(135deg,#edfff6,#d5f5e8);border:1.5px solid #b3f0d6}
.net-neg{background:linear-gradient(135deg,#fff0f4,#ffe8ec);border:1.5px solid #ffccd5}
.brow{margin-bottom:9px;cursor:pointer}
.brow:last-child{margin-bottom:0}
.bmeta{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px}
.bname{font-size:12px;display:flex;align-items:center;gap:5px;font-weight:500}
.bdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.bval{font-size:11px;color:var(--text2);font-weight:500}
.btrack{height:6px;background:var(--gray);border-radius:7px;overflow:hidden}
.bfill{height:100%;border-radius:7px}
.wgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.wcard{background:var(--white);border:1.5px solid var(--border);border-radius:13px;padding:11px;cursor:pointer;transition:transform .15s}
.wcard:active{transform:scale(.97)}
.wcard.hot{border-color:#ffb3c6;background:#fff5f7}
.wcard.good{border-color:#b3f0d6;background:#f0fff8}
.wlbl{font-size:10px;color:var(--text3);font-weight:600;margin-bottom:1px}
.wdates{font-size:9px;color:var(--text3);margin-bottom:4px}
.wamt{font-size:14px;font-weight:800;margin-bottom:3px}
.wbadge{display:inline-flex;align-items:center;font-size:9px;padding:2px 6px;border-radius:8px;font-weight:700}
.wbadge.up{background:#ffe0e6;color:var(--pink)}
.wbadge.dn{background:#e0f5ea;color:var(--mint)}
.wbadge.base{background:var(--gray);color:var(--text3)}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.ccard{border-radius:13px;padding:11px;cursor:pointer;transition:transform .15s;border:1px solid transparent}
.ccard:active{transform:scale(.97)}
.cemoji{font-size:17px;margin-bottom:3px}
.cname{font-size:10px;color:var(--text2);margin-bottom:1px;font-weight:500}
.camt{font-size:13px;font-weight:800}
.cpct{font-size:9px;color:var(--text3)}
.cfilter{display:flex;gap:5px;overflow-x:auto;padding-bottom:3px;scrollbar-width:none;margin-bottom:10px}
.cfilter::-webkit-scrollbar{display:none}
.cpill{flex-shrink:0;padding:4px 11px;border-radius:12px;border:1.5px solid var(--border);background:var(--white);color:var(--text2);font-size:10px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif;transition:all .2s}
.cpill.on{color:#fff;border-color:transparent}
.litem{display:flex;align-items:center;gap:5px;padding:7px 0;border-bottom:1px solid var(--border)}
.litem:last-child{border-bottom:none}
.ldate{color:var(--text3);width:36px;flex-shrink:0;font-size:9px;font-weight:500}
.lname{flex:1;font-weight:500;font-size:11px;color:var(--text);min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ltag{flex-shrink:0;border-radius:8px;padding:2px 5px;font-size:9px;font-weight:700}
.lamt{flex-shrink:0;font-weight:700;font-size:11px}
.lcard{flex-shrink:0;font-size:8px;color:var(--text3);max-width:40px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lbtns{display:flex;gap:2px;flex-shrink:0}
.ldel{background:none;border:none;color:var(--text3);font-size:12px;cursor:pointer;padding:1px 3px}
.ledit{background:none;border:none;color:var(--blue);font-size:11px;cursor:pointer;padding:1px 3px}
.cmpbar{display:flex;align-items:center;gap:6px;margin-bottom:7px}
.cmplbl{width:50px;font-size:10px;color:var(--text2);flex-shrink:0;font-weight:600}
.cmptrack{flex:1;height:22px;background:var(--gray);border-radius:6px;overflow:hidden}
.cmpfill{height:100%;border-radius:6px;display:flex;align-items:center;padding:0 7px;min-width:24px}
.cmpftxt{font-size:9px;font-weight:700;color:#fff;white-space:nowrap}
.cmpamt{width:55px;font-size:10px;font-weight:700;color:var(--text);text-align:right;flex-shrink:0}
.tbl{width:100%;border-collapse:collapse;font-size:10px}
.tbl th{text-align:right;padding:4px 3px;background:var(--gray-l);color:var(--text2);font-size:9px;font-weight:700}
.tbl th:first-child{text-align:left}
.tbl td{padding:5px 3px;border-bottom:1px solid var(--border);text-align:right;color:var(--text2)}
.tbl td:first-child{text-align:left;font-weight:600;color:var(--text)}
.tbl tr:last-child td{border-bottom:none;font-weight:800;color:var(--purple)}
.fxitem{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.fxitem:last-child{border-bottom:none}
.fxl{display:flex;align-items:center;gap:6px}
.fxdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.fxname{font-size:11px;font-weight:600}
.fxsub{font-size:9px;color:var(--text3)}
.fxbtns{display:flex;gap:4px;margin-top:2px}
.fxbtn{font-size:9px;padding:2px 7px;border-radius:6px;border:none;cursor:pointer;font-family:'Noto Sans KR',sans-serif;font-weight:600}
.fxedit{background:#e8f0ff;color:var(--blue)}
.fxdel{background:#ffe8ec;color:var(--pink)}
.puitem{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.puitem:last-child{border-bottom:none}
.pubadge{font-size:9px;font-weight:700;border-radius:6px;padding:2px 6px}
.pubadge.out{background:#ffe8ec;color:var(--pink)}
.pubadge.in{background:#e8fff3;color:var(--mint)}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;align-items:flex-end;justify-content:center}
.modal-bg.on{display:flex}
.modal{background:var(--white);border-radius:20px 20px 0 0;padding:18px 16px 32px;width:100%;max-width:480px;max-height:88vh;overflow-y:auto}
.modal h3{font-size:14px;font-weight:800;margin-bottom:14px}
.mrow{margin-bottom:10px}
.mrow label{font-size:10px;font-weight:700;color:var(--text2);display:block;margin-bottom:2px}
.mrow input,.mrow select{width:100%;padding:9px 11px;border:1.5px solid var(--border);border-radius:10px;font-size:12px;font-family:'Noto Sans KR',sans-serif;color:var(--text);background:var(--white);outline:none}
.mrow input:focus,.mrow select:focus{border-color:var(--purple)}
.mbtns{display:flex;gap:8px;margin-top:14px}
.mbtn{flex:1;padding:11px;border-radius:11px;border:none;font-size:13px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif}
.mbtn.ok{background:var(--purple);color:#fff}
.mbtn.cancel{background:var(--gray);color:var(--text2)}
.type-toggle{display:flex;border-radius:10px;overflow:hidden;border:1.5px solid var(--border);margin-bottom:10px}
.type-btn{flex:1;padding:9px;border:none;background:var(--white);font-size:12px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif;color:var(--text2);transition:all .2s}
.type-btn.ae{background:#fff0f4;color:var(--pink)}
.type-btn.ai{background:#edfff6;color:var(--mint)}
.fab{position:fixed;bottom:82px;right:16px;width:48px;height:48px;border-radius:50%;background:var(--purple);color:#fff;font-size:22px;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(155,127,232,.4);display:flex;align-items:center;justify-content:center;z-index:90;transition:transform .2s}
.fab:active{transform:scale(.93)}
.slbl{font-size:9px;letter-spacing:2px;color:var(--text3);margin:12px 0 6px;font-weight:700}
.ctabs{display:flex;gap:6px;margin-bottom:11px}
.ctab{flex:1;padding:7px;border-radius:10px;border:1.5px solid var(--border);background:var(--white);font-size:11px;font-weight:700;color:var(--text2);cursor:pointer;font-family:'Noto Sans KR',sans-serif;text-align:center;transition:all .2s}
.ctab.on{background:var(--purple);color:#fff;border-color:var(--purple)}
/* 주차 분석 */
.wdetail{background:rgba(255,255,255,.9);border-radius:12px;padding:12px;margin-bottom:8px;border:1px solid var(--border)}
.wdetail.warn{border-color:#ffb3c6;background:#fff8fa}
.wdetail.ok{border-color:#b3f0d6;background:#f5fff9}
.wdtop{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.wdtitle{font-size:12px;font-weight:800}
.wdamt{font-size:13px;font-weight:800}
.problem-box{border-radius:10px;padding:8px 10px;margin-bottom:6px;font-size:11px;line-height:1.6}
.problem-box:last-child{margin-bottom:0}
.problem-box.red{background:#fff0f4;border-left:3px solid var(--pink);color:#c03050}
.problem-box.orange{background:#fff8f0;border-left:3px solid var(--orange);color:#b05020}
.problem-box.green{background:#edfff6;border-left:3px solid var(--mint);color:#1a7a48}
.problem-box.blue{background:#eef4ff;border-left:3px solid var(--blue);color:#2050b0}
/* 자산 */
.asset-total{background:linear-gradient(135deg,#3d3554,#6040a0);border-radius:20px;padding:20px 16px;margin-bottom:10px;color:#fff;position:relative;overflow:hidden}
.asset-total::after{content:'🏦';position:absolute;right:14px;top:14px;font-size:32px;opacity:.2}
.asset-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.asset-row:last-child{border-bottom:none}
.asset-name{font-size:12px;font-weight:600}
.asset-sub{font-size:10px;color:var(--text3)}
.asset-val{font-size:13px;font-weight:700}
.asset-val.pos{color:var(--mint)}
.asset-val.neg{color:var(--pink)}
.asset-val.neu{color:var(--text2)}
.asset-section{border-radius:12px;padding:3px 0;margin-bottom:2px}
.asset-sec-title{font-size:10px;font-weight:700;letter-spacing:1px;color:var(--text3);padding:8px 0 4px}
/* 저축 */
.saving-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.saving-item:last-child{border-bottom:none}
.saving-badge{font-size:9px;font-weight:700;border-radius:6px;padding:2px 6px;background:#e8f0ff;color:var(--blue)}
.saving-badge.stock{background:#fff0e8;color:var(--orange)}
.saving-badge.purpose{background:#f0e8ff;color:var(--purple)}
/* TAG */
.t식비{background:#ffe8ec;color:#e05070}.t생활용품{background:#e8f0ff;color:#4070e0}
.t건강{background:#e8fff3;color:#2ea868}.t자녀{background:#fff0e8;color:#d06030}
.t자동차{background:#fff8e0;color:#c08020}.t꾸밈비{background:#ffe8f8;color:#c040a0}
.t자기계발{background:#e8ffe8;color:#208020}.t경조사{background:#fff5e8;color:#b06020}
.t기타{background:#f0eef8;color:#9080b0}.t고정지출{background:#e8f8ff;color:#2090c0}
.t여행{background:#f0e8ff;color:#7040c0}.t목적통장{background:#e8f0ff;color:#4070e0}
.t급여{background:#e8fff3;color:#2ea868}.t상여금{background:#d5f5e8;color:#1a8a58}
.t해미월급{background:#e8fff3;color:#2ea868}.t영빈월급{background:#edfff6;color:#2ea868}
.t아동수당{background:#fff0e8;color:#d06030}.t기타수입{background:#e8f5ee;color:#4a9a6a}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
.fade{animation:fadeUp .22s ease both}
</style>
</head>
<body>

<div id="pg-home" class="pg on">
  <div class="pghd"><div class="pgtitle">월별 <em>리포트</em> 📊</div></div>
  <div class="mtabs" id="home-mtabs"></div>
  <div id="home-body"></div>
</div>

<div id="pg-detail" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">지출 <em>내역</em> 📋</div></div>
  <div class="mtabs" id="detail-mtabs"></div>
  <div id="detail-body"></div>
</div>

<div id="pg-income" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">수입 <em>내역</em> 💵</div></div>
  <div class="mtabs" id="income-mtabs"></div>
  <div id="income-body"></div>
</div>

<div id="pg-saving" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">저축 <em>현황</em> 💎</div>
    <button onclick="openSavingModal()" style="background:var(--purple);color:#fff;border:none;border-radius:9px;padding:6px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif">+ 추가</button>
  </div>
  <div class="mtabs" id="saving-mtabs"></div>
  <div id="saving-body"></div>
</div>

<div id="pg-asset" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">자산 <em>현황</em> 🏦</div>
    <button onclick="openAssetModal()" style="background:var(--purple);color:#fff;border:none;border-radius:9px;padding:6px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif">+ 스냅샷</button>
  </div>
  <div id="asset-body"></div>
</div>

<div id="pg-compare" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">월별 <em>비교</em> 📈</div></div>
  <div id="compare-body"></div>
</div>

<div id="pg-fixed" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">고정비 <em>관리</em> 📌</div>
    <button onclick="openFixedModal()" style="background:var(--purple);color:#fff;border:none;border-radius:9px;padding:6px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif">+ 추가</button>
  </div>
  <div id="fixed-body"></div>
</div>

<div id="pg-purpose" class="pg">
  <div class="pghd"><button class="back-btn" onclick="goBack()">←</button><div class="pgtitle">목적 <em>통장</em> 💰</div>
    <button onclick="openPurposeModal()" style="background:var(--purple);color:#fff;border:none;border-radius:9px;padding:6px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif">+ 추가</button>
  </div>
  <div id="purpose-body"></div>
</div>

<div class="bnav">
  <button class="nbtn on"  onclick="showPg('home')"><span class="ni">🏠</span>홈</button>
  <button class="nbtn"     onclick="showPg('detail')"><span class="ni">📋</span>지출</button>
  <button class="nbtn"     onclick="showPg('income')"><span class="ni">💵</span>수입</button>
  <button class="nbtn"     onclick="showPg('saving')"><span class="ni">💎</span>저축</button>
  <button class="nbtn"     onclick="showPg('asset')"><span class="ni">🏦</span>자산</button>
  <button class="nbtn"     onclick="showPg('compare')"><span class="ni">📊</span>비교</button>
  <button class="nbtn"     onclick="showPg('fixed')"><span class="ni">📌</span>고정비</button>
  <button class="nbtn"     onclick="showPg('purpose')"><span class="ni">💰</span>목적통장</button>
</div>

<button class="fab" id="fab-btn" style="display:none" onclick="onFabClick()">+</button>

<!-- MODAL TX -->
<div class="modal-bg" id="modal-tx">
  <div class="modal">
    <h3 id="modal-tx-title">💸 내역 추가</h3>
    <input type="hidden" id="tx-edit-id">
    <div class="type-toggle">
      <button class="type-btn ae" id="btn-type-exp" onclick="setTxType('지출')">💸 지출</button>
      <button class="type-btn"    id="btn-type-inc" onclick="setTxType('수입')">💵 수입</button>
    </div>
    <div class="mrow"><label>날짜</label><input type="date" id="tx-date"></div>
    <div class="mrow"><label>항목명</label><input type="text" id="tx-name"></div>
    <div class="mrow"><label>카테고리</label><select id="tx-cat"></select></div>
    <div class="mrow"><label>금액 (원)</label><input type="number" id="tx-amt"></div>
    <div class="mrow"><label>카드/은행</label><input type="text" id="tx-card"></div>
    <div class="mbtns">
      <button class="mbtn cancel" onclick="closeTxModal()">취소</button>
      <button class="mbtn ok" onclick="saveTx()">저장</button>
    </div>
