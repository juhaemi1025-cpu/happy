    </div>`;
  }).join('');

  // 이달 종합 문제점
  const monthProblems=getMonthProblems(expTxs,cats,totalInc,totalExp,net);

  const incBarHtml=sortedInc.length?sortedInc.map(([cat,amt])=>`
    <div class="brow" onclick="showPg('income')">
      <div class="bmeta"><div class="bname"><div class="bdot" style="background:${CAT_COLOR[cat]||'#2ea868'}"></div>${CAT_EMOJI[cat]||'💵'} ${cat}</div>
      <div class="bval">${fmt(amt)}원 (${Math.round(amt/totalInc*100)}%)</div></div>
      <div class="btrack"><div class="bfill" style="width:${Math.round(amt/maxInc*100)}%;background:${CAT_COLOR[cat]||'#2ea868'}"></div></div>
    </div>`).join(''):`<div style="color:var(--text3);font-size:11px;text-align:center;padding:8px">수입 내역 없음 — 수입 탭에서 추가하세요</div>`;

  document.getElementById('home-body').innerHTML=`
  <div class="hero fade" style="background:linear-gradient(135deg,#e8d5ff,#d5e8ff,#d5f5e8)">
    <div class="hlabel">이달 순수지</div>
    <div class="hamount" style="color:${net>=0?'#2ea868':'#e05070'}">${net>=0?'+':''}${fmt(net)}<span class="won">원</span></div>
    <div class="hchips"><div class="hchip">💵 수입 <b>${fmtK(totalInc)}원</b></div><div class="hchip">💸 지출 <b>${fmtK(totalExp)}원</b></div></div>
  </div>
  <div class="ie-grid fade">
    <div class="ie-card income"><div class="ie-lbl inc">💵 총 수입</div><div class="ie-amt inc">${fmt(totalInc)}<span style="font-size:10px">원</span></div><div class="ie-sub">${incTxs.length}건</div></div>
    <div class="ie-card expense"><div class="ie-lbl exp">💸 총 지출</div><div class="ie-amt exp">${fmt(totalExp)}<span style="font-size:10px">원</span></div><div class="ie-sub">${expTxs.length}건</div></div>
  </div>
  <div class="net-card fade ${net>=0?'net-pos':'net-neg'}">
    <div><div style="font-size:10px;font-weight:700;color:var(--text2)">${net>=0?'💚 흑자':'🔴 적자'}</div><div style="font-size:9px;color:var(--text3)">${net>=0?'잘 아끼고 있어요!':'지출이 수입을 초과했어요'}</div></div>
    <div style="font-size:18px;font-weight:900;color:${net>=0?'#2ea868':'#e05070'}">${net>=0?'+':''}${fmt(net)}원</div>
  </div>
  <div class="card fade"><div class="ctitle">💵 수입 현황 <span class="sub" onclick="showPg('income')" style="cursor:pointer;color:var(--purple)">전체 보기 →</span></div>${incBarHtml}</div>
