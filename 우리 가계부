function openTxModal(){
  document.getElementById('modal-tx-title').textContent='💸 내역 추가';
  document.getElementById('tx-edit-id').value='';
  document.getElementById('tx-date').value=new Date().toISOString().slice(0,10);
  document.getElementById('tx-name').value='';document.getElementById('tx-amt').value='';document.getElementById('tx-card').value='';
  const pg=pgHistory[pgHistory.length-1];
  setTxType(pg==='income'?'수입':'지출');
  document.getElementById('modal-tx').classList.add('on');
}
function openEditTx(id){
  const t=TX.find(x=>x.id===id);if(!t)return;
  document.getElementById('modal-tx-title').textContent='✏️ 내역 수정';
  document.getElementById('tx-edit-id').value=id;
  document.getElementById('tx-date').value=t.date;
  document.getElementById('tx-name').value=t.name;
  document.getElementById('tx-amt').value=t.amt;
  document.getElementById('tx-card').value=t.card||'';
  setTxType(t.type||'지출');
  setTimeout(()=>{document.getElementById('tx-cat').value=t.cat;},20);
  document.getElementById('modal-tx').classList.add('on');
}
function closeTxModal(){document.getElementById('modal-tx').classList.remove('on');}
function saveTx(){
  const eid=document.getElementById('tx-edit-id').value;
  const date=document.getElementById('tx-date').value;
  const name=document.getElementById('tx-name').value.trim();
  const cat=document.getElementById('tx-cat').value;
  const amt=parseInt(document.getElementById('tx-amt').value)||0;
  const card=document.getElementById('tx-card').value.trim();
  const type=curTxType;
  if(!name||!amt){alert('항목명과 금액을 입력해주세요');return;}
  const d=new Date(date);
  const item={id:eid||uid(),date,name,cat,amt,card,type,year:d.getFullYear(),month:d.getMonth()+1,week:Math.ceil(d.getDate()/7)};
  if(eid){const idx=TX.findIndex(t=>t.id===eid);if(idx>-1)TX[idx]=item;}else TX.push(item);
  save();closeTxModal();
  const pg=pgHistory[pgHistory.length-1];
  if(pg==='detail')renderDetail(curMonth,curCat);
  else if(pg==='income')renderIncome(curMonth);
  else renderHome(curMonth);
}
function delTx(id){
  if(!confirm('삭제할까요?'))return;
  TX=TX.filter(t=>t.id!==id);save();
  const pg=pgHistory[pgHistory.length-1];
  if(pg==='detail')renderDetail(curMonth,curCat);
  else if(pg==='income')renderIncome(curMonth);
}
function importJson(){
  try{
    const raw=document.getElementById('import-json').value.trim();
    const arr=JSON.parse(raw);let added=0;
    arr.forEach(item=>{
      const ds=item.date||new Date().toISOString().slice(0,10);const d=new Date(ds);
      if(!TX.find(t=>t.name===item.name&&t.amt===item.amt&&t.date===ds)){
        TX.push({id:uid(),date:ds,name:item.name||'',cat:item.cat||'기타',amt:item.amt||0,card:item.card||'',type:item.type||'지출',year:d.getFullYear(),month:d.getMonth()+1,week:item.week||Math.ceil(d.getDate()/7)});added++;
      }
    });
    save();closeTxModal();alert(`${added}건 추가됐어요!`);
    renderDetail(curMonth,curCat);
  }catch(e){alert('JSON 형식이 올바르지 않아요.');}
}

