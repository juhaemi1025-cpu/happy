    const foodAmt=wTxs.filter(t=>t.cat==='식비').reduce((s,t)=>s+t.amt,0);
    const deliveries=wTxs.filter(t=>t.name.includes('배달')||t.name.includes('배민'));
    const smokes=wTxs.filter(t=>t.name.includes('담배')||t.name.includes('GS25')||t.name.includes('세븐일레븐'));
    const beauty=wTxs.filter(t=>t.cat==='꾸밈비').reduce((s,t)=>s+t.amt,0);
