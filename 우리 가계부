// ===== ASSET =====
function renderAsset(){
  const snaps=ASSET_SNAPSHOTS.sort((a,b)=>a.date.localeCompare(b.date));
  if(!snaps.length){document.getElementById('asset-body').innerHTML='<div style="text-align:center;padding:30px;color:var(--text3)">자산 스냅샷이 없어요<br>+ 스냅샷 버튼으로 추가하세요</div>';return;}
  const latest=snaps[snaps.length-1];
  const latestItems=latest.items;
  const totalAsset=latestItems.filter(i=>i.amt>0).reduce((s,i)=>s+i.amt,0);
  const totalDebt=latestItems.filter(i=>i.amt<0).reduce((s,i)=>s+i.amt,0);
  const netAsset=totalAsset+totalDebt;

  // 순자산 추이
  const trendHtml=snaps.map(snap=>{
    const pos=snap.items.filter(i=>i.amt>0).reduce((s,i)=>s+i.amt,0);
    const neg=snap.items.filter(i=>i.amt<0).reduce((s,i)=>s+i.amt,0);
    const net=pos+neg;
    const maxNet=Math.max(...snaps.map(s=>{const p=s.items.filter(i=>i.amt>0).reduce((a,i)=>a+i.amt,0);const n=s.items.filter(i=>i.amt<0).reduce((a,i)=>a+i.amt,0);return p+n;}),1);
    const pct=Math.max(Math.round(net/maxNet*100),5);
    return `<div class="cmpbar"><div class="cmplbl" style="font-size:9px">${snap.label}</div>
      <div class="cmptrack"><div class="cmpfill" style="width:${pct}%;background:${snap===latest?'#9b7fe8':'#c4b0f0'}"><span class="cmpftxt">${fmtK(net)}</span></div></div>
      <div class="cmpamt">${fmtK(net)}</div></div>`;
  }).join('');

  // 카테고리별 최신 자산
  const catGroups={};
  latestItems.forEach(item=>{
    if(!catGroups[item.cat])catGroups[item.cat]=[];
    catGroups[item.cat].push(item);
  });
  const catOrder=['부동산','저축_청약','주식','노후','현금','자녀','대출'];
  const catHtml=catOrder.filter(c=>catGroups[c]).map(cat=>{
    const items=catGroups[cat];
    const catTotal=items.reduce((s,i)=>s+i.amt,0);
    const isDebt=cat==='대출';
    return `<div class="card fade">
      <div class="ctitle" style="color:${ASSET_CAT_COLOR[cat]||'#9b7fe8'}">${ASSET_CAT_EMOJI[cat]||'💰'} ${cat==='저축_청약'?'저축/청약':cat} <span class="sub">${isDebt?'-':'+'}${fmt(Math.abs(catTotal))}원</span></div>
      ${items.map(item=>{
        // 이전 스냅샷과 비교
        const prev=snaps.length>1?snaps[snaps.length-2].items.find(i=>i.key===item.key):null;
        const chg=prev?item.amt-prev.amt:null;
        return `<div class="asset-row">
          <div><div class="asset-name">${item.name}</div>
          ${chg!==null?`<div class="asset-sub">${chg>=0?'▲':'▼'} ${fmt(Math.abs(chg))}원 (${prev&&prev.amt!==0?((chg/Math.abs(prev.amt))*100).toFixed(1):'∞'}%)</div>`:''}</div>
          <div>
            <div class="asset-val ${item.amt>0?'pos':item.amt<0?'neg':'neu'}">${item.amt>0?'+':''}${fmt(item.amt)}원</div>
            <div class="lbtns" style="justify-content:flex-end;margin-top:2px"><button class="ledit" onclick="openEditAsset('${item.key}')">✏️</button></div>
          </div>
        </div>`;
      }).join('')}
    </div>`;
  }).join('');

  // 스냅샷 히스토리 비교 테이블
  const allKeys=[...new Set(snaps.flatMap(s=>s.items.map(i=>i.key)))];
  const keyMeta={};
  snaps.forEach(s=>s.items.forEach(i=>{keyMeta[i.key]={name:i.name,cat:i.cat};}));
  const tblRows=allKeys.map(key=>{
    const vals=snaps.map(s=>s.items.find(i=>i.key===key)?.amt??null);
    if(vals.every(v=>v===null))return'';
    const latest_v=vals[vals.length-1];
    const first_v=vals.find(v=>v!==null);
    const totalChg=latest_v!==null&&first_v!==null?latest_v-first_v:null;
    return `<tr><td>${ASSET_CAT_EMOJI[keyMeta[key]?.cat]||''} ${keyMeta[key]?.name||key}</td>
      ${vals.map(v=>v!==null?`<td style="${v<0?'color:#e05070':v>0?'color:#2ea868':''}">${fmtK(v)}</td>`:`<td style="color:var(--text3)">—</td>`).join('')}
      <td style="${totalChg&&totalChg>0?'color:#2ea868;font-weight:800':totalChg&&totalChg<0?'color:#e05070;font-weight:800':''}">${totalChg!==null?(totalChg>=0?'+':'')+fmtK(totalChg):'—'}</td>
    </tr>`;
  }).join('');

  document.getElementById('asset-body').innerHTML=`
  <div class="asset-total fade">
    <div style="font-size:10px;letter-spacing:1.5px;opacity:.7;margin-bottom:3px">순자산 (${latest.label} 기준)</div>
    <div style="font-size:28px;font-weight:900;letter-spacing:-1px">${fmt(netAsset)}<span style="font-size:15px">원</span></div>
    <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap">
      <div style="background:rgba(255,255,255,.15);border-radius:9px;padding:3px 10px;font-size:10px">🏦 자산 +${fmtK(totalAsset)}</div>
      <div style="background:rgba(255,255,255,.15);border-radius:9px;padding:3px 10px;font-size:10px">📉 부채 -${fmtK(Math.abs(totalDebt))}</div>
    </div>
  </div>
  <div class="card fade"><div class="ctitle">📈 순자산 추이</div>${trendHtml}</div>
  ${catHtml}
  <div class="card fade"><div class="ctitle">📊 전체 자산 변화 비교</div>
    <div style="overflow-x:auto"><table class="tbl" style="min-width:320px">
      <thead><tr><th>항목</th>${snaps.map(s=>`<th>${s.label}</th>`).join('')}<th>변화</th></tr></thead>
      <tbody>${tblRows}
        <tr><td>순자산</td>${snaps.map(s=>{const p=s.items.filter(i=>i.amt>0).reduce((a,i)=>a+i.amt,0);const n=s.items.filter(i=>i.amt<0).reduce((a,i)=>a+i.amt,0);const net=p+n;return`<td style="color:${net>=0?'#2ea868':'#e05070'};font-weight:800">${fmtK(net)}</td>`;}).join('')}
        <td style="color:var(--purple);font-weight:800">${(()=>{const first=snaps[0];const last=snaps[snaps.length-1];const fp=first.items.filter(i=>i.amt>0).reduce((a,i)=>a+i.amt,0)+first.items.filter(i=>i.amt<0).reduce((a,i)=>a+i.amt,0);const lp=last.items.filter(i=>i.amt>0).reduce((a,i)=>a+i.amt,0)+last.items.filter(i=>i.amt<0).reduce((a,i)=>a+i.amt,0);const d=lp-fp;return(d>=0?'+':'')+fmtK(d);})()}</td></tr>
      </tbody>
    </table></div>
  </div>`;
}

